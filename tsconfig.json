{
    "extends": "@tsconfig/recommended/tsconfig.json",
    "compilerOptions": {
        "baseUrl": "./src",
        "jsx": "react-jsx",
        "moduleResolution": "Node",
        "ignoreDeprecations": "6.0",
        "types": [
            "chrome",
            "node"
        ],
        "rootDir": "./src",
        "noEmit": false,
        "noFallthroughCasesInSwitch": true,
        "outDir": "./dist/js",
    },
    "display": "Wppconnect",
    "exclude": [
        "node_modules"
    ],
    "include": [
        "./src"
    ]
}
