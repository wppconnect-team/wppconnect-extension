{
    "extends": "@tsconfig/recommended/tsconfig.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "ignoreDeprecations": "6.0",
        "paths": {
            "*": [
                "./src/*"
            ],
            "@wppconnect/wa-js/dist/*": [
                "./node_modules/@wppconnect/wa-js/dist/*"
            ]
        },
        "types": [
            "chrome",
            "node"
        ],
        "rootDir": "./src",
        "noEmit": false,
        "noFallthroughCasesInSwitch": true,
        "outDir": "./dist/js",
    },
    "display": "Wppconnect",
    "exclude": [
        "node_modules"
    ],
    "include": [
        "./src"
    ]
}
